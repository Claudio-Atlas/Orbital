{
  "meta": {
    "topic": "Scene Generator v3 — All Step Types Test",
    "product_family": "test"
  },
  "steps": [
    {
      "type": "text",
      "content": "Scene Generator v3 — Testing All Step Types",
      "narration": "Welcome to the scene generator version three test."
    },
    {
      "type": "math",
      "content": "f(x) = x^2",
      "narration": "Let's start with a simple function."
    },
    {
      "type": "graph",
      "narration": "Here is the graph of f of x equals x squared.",
      "graph": {
        "kind": "function_plot",
        "x_range": [-3, 3, 1],
        "y_range": [-1, 9, 1],
        "functions": [
          {"expr": "lambda x: x**2", "color": "#8B5CF6", "label": "f(x) = x^2"}
        ],
        "points": [{"x": 1, "y": 1, "label": "(1,1)", "color": "#FACC15"}],
        "axis_labels": ["x", "y"]
      }
    },
    {
      "type": "graph",
      "narration": "Now let's see the tangent line at x equals 1.",
      "graph": {
        "kind": "tangent_line",
        "x_range": [-3, 3, 1],
        "y_range": [-1, 9, 1],
        "functions": [
          {"expr": "lambda x: x**2", "color": "#8B5CF6", "label": "f(x) = x^2"},
          {"expr": "lambda x: 2*x - 1", "color": "#22D3EE", "label": "y = 2x - 1", "dashed": true}
        ],
        "points": [{"x": 1, "y": 1, "label": "(1,1)", "color": "#FACC15"}],
        "axis_labels": ["x", "y"]
      }
    },
    {
      "type": "graph",
      "narration": "And the area under the curve from 0 to 2.",
      "graph": {
        "kind": "area_under",
        "x_range": [-1, 3, 1],
        "y_range": [-1, 5, 1],
        "functions": [
          {"expr": "lambda x: x**2", "color": "#8B5CF6", "label": "f(x) = x^2"}
        ],
        "shaded_area": {"func_index": 0, "x_range": [0, 2], "color": "#39FF14", "opacity": 0.3},
        "axis_labels": ["x", "y"]
      }
    },
    {
      "type": "transform",
      "narration": "Watch the integral simplify step by step.",
      "transform": {
        "from_latex": "\\int_0^1 x^2 \\, dx",
        "to_latex": "\\frac{1}{3}",
        "intermediate_steps": [
          "\\frac{x^3}{3} \\Big|_0^1",
          "\\frac{1^3}{3} - \\frac{0^3}{3}"
        ]
      }
    },
    {
      "type": "geometric",
      "narration": "Consider this right triangle with angle theta.",
      "geometric": {
        "kind": "triangle",
        "shapes": [
          {"type": "polygon", "vertices": [[0,0], [3,0], [3,2]], "color": "#8B5CF6", "label": "ABC"},
          {"type": "angle", "vertex": [0,0], "ray1": [3,0], "ray2": [3,2], "label": "\\theta", "radius": 0.5, "color": "#14B8A6"}
        ],
        "labels": [
          {"text": "3", "position": [1.5, -0.4]},
          {"text": "2", "position": [3.4, 1.0]}
        ]
      }
    },
    {
      "type": "box",
      "label": "Result",
      "content": "The scene generator now supports all visual types!",
      "narration": "And that completes our test of all visual types."
    }
  ]
}
