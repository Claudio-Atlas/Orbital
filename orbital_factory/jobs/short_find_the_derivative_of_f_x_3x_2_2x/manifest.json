  {
    "type": "box",
    "content": "\\frac{d}{dx}[x^n] = n \\cdot x^{n-1}",
    "narration": "Our main tool is the power rule. The exponent comes down as a multiplier, and the new exponent is one less than before.",
    "mode": "replace",
