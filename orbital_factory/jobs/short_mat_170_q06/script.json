        "steps": [
          {
            "latex": "\\text{Possible: } \\pm \\frac{\\text{factors of 100}}{\\text{factors of 3}}",
            "narration": "By the Rational Root Theorem, we test factors of 100 over factors of 3."
          },
          {
            "latex": "f\\left(\\tfrac{5}{3}\\right) = 3\\left(\\tfrac{125}{27}\\right) + 22\\left(\\tfrac{25}{9}\\right) + 15\\left(\\tfrac{5}{3}\\right) - 100 = 0 \\checkmark",
            "narration": "Testing x equals 5 thirds. It works out to zero."
          },
          {
            "latex": "(3x - 5)(x^2 + 9x + 20) = 0",
            "narration": "Divide out 3 x minus 5. The quotient is x squared plus 9 x plus 20.",
            "note": "synthetic division"
          },
          {
            "latex": "(3x - 5)(x + 4)(x + 5) = 0",
            "narration": "Factor the quadratic: x plus 4 times x plus 5."
          }
        ]
      }
    },
    {
      "type": "box",
      "content": "x = 5/3 (mult 1),  x = -4 (mult 1),  x = -5 (mult 1)",
